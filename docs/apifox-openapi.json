  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int32"
        }
      },
      "QuestionTypeQuery": {
        "name": "type",
        "in": "query",
        "schema": {
          "$ref": "#/components/schemas/QuestionType"
        }
      },
      "CollectionTypeQuery": {
        "name": "type",
        "in": "query",
        "schema": {
          "$ref": "#/components/schemas/CollectionType"
        }
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 401
          },
          "message": {
            "type": "string",
            "example": "Unauthorized"
          },
          "data": {
            "nullable": true,
            "example": null
          }
        }
      },
      "QuestionType": {
        "type": "string",
        "enum": [
          "SingleChoice",
          "MultiChoice",
          "TrueFalse"
        ]
      },
      "Answer": {
        "type": "string",
        "enum": [
          "A",
          "B",
          "C",
          "D"
        ]
      },
      "CollectionType": {
        "type": "string",
        "enum": [
          "Mistake",
          "Note"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "required": [
          "name",
          "phone",
          "password",
          "confirmPassword"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "minLength": 11,
            "maxLength": 11
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "maxLength": 12,
            "format": "password"
          },
          "confirmPassword": {
            "type": "string",
            "minLength": 6,
            "maxLength": 12,
            "format": "password"
          }
        }
      },
      "LoginDto": {
        "type": "object",
        "required": [
          "phone",
          "password"
        ],
        "properties": {
          "phone": {
            "type": "string",
            "minLength": 11,
            "maxLength": 11
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "minLength": 11,
            "maxLength": 11
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "maxLength": 12,
            "format": "password"
          }
        }
      },
      "OptionDto": {
        "type": "object",
        "required": [
          "key",
          "text"
        ],
        "properties": {
          "key": {
            "$ref": "#/components/schemas/Answer"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "CreateQuestionDto": {
        "type": "object",
        "required": [
          "type",
          "content",
          "options",
          "answer",
          "bank",
          "discipline"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/QuestionType"
          },
          "content": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": {
              "$ref": "#/components/schemas/OptionDto"
            }
          },
          "answer": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Answer"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Answer"
                }
              }
            ]
          },
          "bank": {
            "type": "string"
          },
          "discipline": {
            "type": "string"
          }
        }
      },
      "CheckAnswerDto": {
        "type": "object",
        "required": [
          "questionId",
          "answer"
        ],
        "properties": {
          "questionId": {
            "type": "number"
          },
          "answer": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Answer"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Answer"
                }
              }
            ]
          }
        }
      },
      "CreateCollectionDto": {
        "type": "object",
        "required": [
          "questionId"
        ],
        "properties": {
          "questionId": {
            "type": "number"
          },
          "type": {
            "$ref": "#/components/schemas/CollectionType"
          }
        }
      },
      "CreateBankDto": {
        "type": "object",
        "required": [
          "name",
          "description",
          "creator",
          "disciplines"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "creator": {
            "type": "string"
          },
          "disciplines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CreateDisciplineDto": {
        "type": "object",
        "required": [
          "discipline"
        ],
        "properties": {
          "discipline": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          }
        }
      }
    },
    "responses": {
      "SuccessAny": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiResponse"
            }
          }
        }
      },
      "SuccessString": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ApiResponse"
                },
                {
                  "type": "object",
                  "properties": {
