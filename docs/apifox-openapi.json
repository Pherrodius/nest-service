              "type": "string"
            }
          },
          {
            "name": "disciplineId",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "number",
            "in": "query",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessAny"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "Question"
        ],
        "summary": "Create one or many questions",
        "operationId": "createQuestion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/CreateQuestionDto"
                  },
                  {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/CreateQuestionDto"
                    }
                  }
                ]
              },
              "examples": {
                "single": {
                  "value": {
                    "type": "SingleChoice",
                    "content": "1 + 1 = ?",
                    "options": [
                      {
                        "key": "A",
                        "text": "1"
                      },
                      {
                        "key": "B",
                        "text": "2"
                      }
                    ],
                    "answer": "B",
                    "bank": "默认题库",
                    "discipline": "数学"
                  }
                },
                "many": {
                  "value": [
                    {
                      "type": "TrueFalse",
                      "content": "太阳从东方升起",
                      "options": [
                        {
                          "key": "A",
                          "text": "正确"
                        },
                        {
                          "key": "B",
                          "text": "错误"
                        }
                      ],
                      "answer": "A",
                      "bank": "默认题库",
                      "discipline": "常识"
                    }
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessAny"
          },
          "400": {
            "$ref": "#/components/responses/Error"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
