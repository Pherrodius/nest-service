// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  phone       String       @unique
  password    String
  createdTime DateTime     @default(now())
  collect     Collection[]
  banks       Bank[]
  resolutions Resolution[]
}

enum QuestionType {
  SingleChoice
  MultiChoice
  TrueFalse
}

enum Answer {
  A
  B
  C
  D
}

model Bank {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String
  questions   Question[]
  disciplines Discipline[]
  creatorId   Int
  creator     User         @relation(fields: [creatorId], references: [id])
  createdTime DateTime     @default(now())
}

model Discipline {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  discipline Bank[]
  questions  Question[]
}

model Question {
  id                Int                 @id @default(autoincrement())
  type              QuestionType
  content           String
  options           Option[]
  bankId            Int
  disciplineId      Int
  createdTime       DateTime            @default(now())
  singleAnswer      SingleAnswer?
  multiChoiceAnswer MultiChoiceAnswer[]
  trueFalseAnswer   TrueFalseAnswer?
  collected         Collection[]
  bank              Bank                @relation(fields: [bankId], references: [id])
  discipline        Discipline          @relation(fields: [disciplineId], references: [id])
  resolutions       Resolution[]
}

model Option {
  id         Int      @id @default(autoincrement())
  key        Answer
  text       String
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([questionId, key])
}

model SingleAnswer {
  questionId Int      @id
  answerKey  Answer
  question   Question @relation(fields: [questionId], references: [id])
}

model MultiChoiceAnswer {
  id         Int      @id @default(autoincrement())
  questionId Int
  answerKey  Answer
  question   Question @relation(fields: [questionId], references: [id])
}

model TrueFalseAnswer {
  questionId Int      @id
  answerKey  Answer
  question   Question @relation(fields: [questionId], references: [id])
}

enum CollectionType {
  Mistake
  Note
}

model Collection {
  id          Int            @id @default(autoincrement())
  userId      Int
  questionId  Int
  updatedTime DateTime       @default(now())
  type        CollectionType @default(Note)
  creator     User           @relation(fields: [userId], references: [id])
  question    Question       @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId, type])
}

model Resolution {
  id          Int      @id @default(autoincrement())
  userId      Int
  questionId  Int
  updatedTime DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}
