// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  phone           String           @unique
  password        String
  createdTime     DateTime         @default(now())
  collect         Collection[]
  banks           Bank[]
  resolutions     Resolution[]
  bankCollections BankCollection[]
  testHistories   TestHistory[]
  documents       Document[]
}

enum QuestionType {
  SingleChoice
  MultiChoice
  TrueFalse
}

enum Answer {
  A
  B
  C
  D
}

model Bank {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String
  categoryId      Int?
  category        BankCategory?    @relation(fields: [categoryId], references: [id])
  questions       Question[]
  disciplines     Discipline[]
  creatorId       Int
  creator         User             @relation(fields: [creatorId], references: [id])
  createdTime     DateTime         @default(now())
  bankCollections BankCollection[]
  testHistories   TestHistory[]
}

model BankCategory {
  id   Int    @id @default(autoincrement())
  name String @unique

  banks Bank[]
}

model Discipline {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  bank          Bank[]
  questions     Question[]
  testHistories TestHistory[]
}

model Question {
  id                Int                 @id @default(autoincrement())
  type              QuestionType
  content           String
  options           Option[]
  bankId            Int
  disciplineId      Int
  createdTime       DateTime            @default(now())
  singleAnswer      SingleAnswer?
  multiChoiceAnswer MultiChoiceAnswer[]
  trueFalseAnswer   TrueFalseAnswer?
  collected         Collection[]
  bank              Bank                @relation(fields: [bankId], references: [id])
  discipline        Discipline          @relation(fields: [disciplineId], references: [id])
  resolutions       Resolution[]
}

model Option {
  id         Int      @id @default(autoincrement())
  key        Answer
  text       String
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([questionId, key])
}

model SingleAnswer {
  questionId Int      @id
  answerKey  Answer
  question   Question @relation(fields: [questionId], references: [id])
}

model MultiChoiceAnswer {
  id         Int      @id @default(autoincrement())
  questionId Int
  answerKey  Answer
  question   Question @relation(fields: [questionId], references: [id])
}

model TrueFalseAnswer {
  questionId Int      @id
  answerKey  Answer
  question   Question @relation(fields: [questionId], references: [id])
}

enum CollectionType {
  Mistake
  Note
}

model Collection {
  id          Int            @id @default(autoincrement())
  userId      Int
  questionId  Int
  updatedTime DateTime       @default(now())
  type        CollectionType @default(Note)
  user        User           @relation(fields: [userId], references: [id])
  question    Question       @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId, type])
}

model BankCollection {
  id          Int      @id @default(autoincrement())
  userId      Int
  bankId      Int
  updatedTime DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  bank        Bank     @relation(fields: [bankId], references: [id])

  @@unique([userId, bankId])
}

model Resolution {
  id            Int      @id @default(autoincrement())
  userId        Int
  questionId    Int
  updatedTime   DateTime @default(now())
  yourAnswer    Json
  correctAnswer Json
  isCorrect     Boolean
  user          User     @relation(fields: [userId], references: [id])
  question      Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}

model TestHistory {
  id           Int        @id @default(autoincrement())
  userId       Int
  bankId       Int
  disciplineId Int
  accuracy     Float
  takenTime    Int        @default(0) // 单位：ms
  length       Int
  createdTime  DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  bank         Bank       @relation(fields: [bankId], references: [id])
  discipline   Discipline @relation(fields: [disciplineId], references: [id])
}

model Document {
  id            Int              @id @default(autoincrement())
  filename      String           @unique
  originalName  String
  url           String
  size          Int
  categoryId    Int
  mimeType      String
  title         String
  content       String?
  uploaderId    Int
  downloadCount Int              @default(0)
  createdTime   DateTime         @default(now())
  uploader      User             @relation(fields: [uploaderId], references: [id])
  category      DocumentCategory @relation(fields: [categoryId], references: [id])
}

model DocumentCategory {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  documents Document[]
}
